---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Coming Soon">

  <!-- ── Hero ──────────────────────────────────────────────────────────── -->
  <div class="text-center pt-16 pb-12">

    <!-- Hebrew ornament -->
    <p
      class="text-5xl mb-4 select-none opacity-20"
      style="font-family: var(--font-hebrew); color: var(--color-primary);"
      aria-hidden="true"
    >
      אָ בָּ גָּ
    </p>

    <h1
      class="text-5xl font-extrabold mb-4 leading-tight"
      style="color: var(--color-primary);"
    >
      hebrew<span style="color: var(--color-accent);">.tools</span>
    </h1>

    <p class="text-lg text-text-muted max-w-xl mx-auto leading-relaxed">
      Free, simple utilities for Biblical Hebrew students. Coming soon.
    </p>
  </div>

  <!-- ── Coming soon card ──────────────────────────────────────────────── -->
  <div class="max-w-md mx-auto pb-20">
    <div class="bg-bg-card rounded-2xl shadow-sm border border-white overflow-hidden">

      <!-- Green accent strip -->
      <div class="h-1.5 w-full" style="background: var(--color-primary);" />

      <div class="p-8 text-center">
        <!-- Hebrew letter badge -->
        <div
          class="w-16 h-16 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-6"
          style="background: #DCFCE7; color: var(--color-primary); font-family: var(--font-hebrew);"
          aria-hidden="true"
        >
          א
        </div>

        <h2
          class="text-2xl font-bold mb-3"
          style="color: var(--color-primary);"
        >
          Under Construction
        </h2>

        <p class="text-text-muted leading-relaxed mb-6">
          Tools for studying the Hebrew Bible are in the works.
          Check back soon.
        </p>

        <!-- Divider -->
        <div class="border-t border-gray-100 pt-6">
          <p class="text-sm text-text-muted">
            In the meantime, check out
            <a
              href="https://greek.tools"
              class="font-semibold underline underline-offset-2 transition-opacity hover:opacity-70"
              style="color: var(--color-primary);"
            >
              greek.tools
            </a>
          </p>
        </div>
      </div>
    </div>
  </div>

</Layout>
